# Datapulse 环境变量配置模板
# 复制为 .env 并填入真实值：cp .env.example .env
# .env 已加入 .gitignore，不会提交到代码库

# ── PostgreSQL 数据库（必填） ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=datapulse
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_PASSWORD

# ── JWT 签名密钥（必填，生产环境请替换为随机长字符串） ─────────────────────────
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_SECRET_KEY

# ── 本地向量文件根目录（可选，默认 ./nas） ────────────────────────────────────
# 存放 FAISS 索引和 Embedding 向量文件，需要有读写权限
# STORAGE_BASE_PATH=./nas
