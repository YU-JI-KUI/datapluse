# 运行环境标识（决定日志格式）可选：dev stg prod
APP_ENV=dev

# ── PostgreSQL 数据库 ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=datapulse
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_PASSWORD

# ── JWT 签名密钥 ────────────────────────────────────────────────────────────────
# 生成：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=datapulse

# ── 本地向量文件根目录（可选，默认 ./nas） ────────────────────────────────────
# 存放 FAISS 索引，需要有读写权限
STORAGE_BASE_PATH=./nas

# ── Embedding 模型路径 ──────────────────────────
EMBEDDING_MODEL_PATH=./models/xiaobu-embedding-v2

# ── 日志配置 可选────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=/ark-nav/datapulse/logs
LOG_ROTATION=time
LOG_BACKUP_COUNT=30
